rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Catch-all Safeguard
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checks user progress payload integrity
    function isValidUserProgress(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.completedTopics is list && data.completedTopics.size() <= 200
        && data.solvedProblems is list && data.solvedProblems.size() <= 1000
        && data.revisionStreak is int && data.revisionStreak >= 0
        && data.lastActiveDate is string && data.lastActiveDate.size() <= 100;
    }

    // Match rules for user progress
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUserProgress(incoming());
      
      allow update: if isOwner(userId)
        && isValidUserProgress(incoming())
        && incoming().uid == existing().uid; // prevent altering ownership
      
      allow delete: if false; // progress deletion is forbidden
    }
  }
}
